void selection_sort(int a[], int n)
{
    int i, j, least, temp;
    for (i = 0; i < n - 1; i++)
    {
        least = i;

        for (j = i + 1; j < n; j++)
        {

            if (a[j] < a[least])
            {
                least = j;
            }
        }
        if (i != least)
        {
            temp = a[i];
            a[i] = a[least];
            a[least] = temp;
        }
    }
}
