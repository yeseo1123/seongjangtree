#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define N 10000

int *sorted;

void bubble_sort(int a[], int n)
{
    int i, j, temp;
    for (i = n - 1; i > 0; i--)
    {
        for (j = 0; j < i; j++)
        {
            if (a[j] > a[j + 1])
            {
                temp = a[j];
                a[j] = a[j + 1];
                a[j + 1] = temp;
            }
        }
    }
}

void selection_sort(int a[], int n)
{
    int i, j, least, temp;
    for (i = 0; i < n - 1; i++)
    {
        least = i;

        for (j = i + 1; j < n; j++)
        {

            if (a[j] < a[least])
            {
                least = j;
            }
        }
        if (i != least)
        {
            temp = a[i];
            a[i] = a[least];
            a[least] = temp;
        }
    }
}

void insertion_sort(int a[], int n)
{
    int i, j, key;
    for (i = 1; i < n; i++)
    {
        key = a[i];

        for (j = i - 1; j >= 0 && a[j] > key; j--)
        {
            a[j + 1] = a[j];
        }
        a[j + 1] = key;
    }
}

void merge(int a[], int left, int mid, int right) {
    int i = left, j = mid + 1, k = left, l;
    while (i <= mid && j <= right) {
        if (a[i] <= a[j]) sorted[k++] = a[i++];
        else sorted[k++] = a[j++];
    }
    if (i > mid) {
        for (l = j; l <= right; l++) sorted[k++] = a[l];
    } else {
        for (l = i; l <= mid; l++) sorted[k++] = a[l];
    }
    for (l = left; l <= right; l++) a[l] = sorted[l];
}

void merge_sort(int a[], int left, int right) {
    if (left < right) {
        int mid = (left + right) / 2;
        merge_sort(a, left, mid);
        merge_sort(a, mid + 1, right);
        merge(a, left, mid, right);
    }
}

int partition(int a[], int left, int right) {
    int pivot = a[left], low = left, high = right + 1, temp;
    do {
        do { low++; } while (low <= right && a[low] < pivot);
        do { high--; } while (high >= left && a[high] > pivot);
        if (low < high) {
            temp = a[low]; a[low] = a[high]; a[high] = temp;
        }
    } while (low < high);
    temp = a[left]; a[left] = a[high]; a[high] = temp;
    return high;
}

void quick_sort(int a[], int left, int right) {
    if (left < right) {
        int q = partition(a, left, right);
        quick_sort(a, left, q - 1);
        quick_sort(a, q + 1, right);
    }
}

void copy_array(int original[], int target[], int n) {
    for (int i = 0; i < n; i++) target[i] = original[i];
}

int main() {
    int *original = (int *)malloc(sizeof(int) * N);
    int *test_array = (int *)malloc(sizeof(int) * N);
    sorted = (int *)malloc(sizeof(int) * N);
    
    clock_t start, end;

    srand(time(NULL));
    for (int i = 0; i < N; i++) {
        original[i] = rand() % 100000;
    }

    printf("=== 데이터 %d개 기준 정렬 시간 비교 실험 ===\n\n", N);

    copy_array(original, test_array, N);
    start = clock();
    bubble_sort(test_array, N);
    end = clock();
    printf("Bubble Sort    : %.3f 초\n", (float)(end - start) / CLOCKS_PER_SEC);

    copy_array(original, test_array, N);
    start = clock();
    selection_sort(test_array, N);
    end = clock();
    printf("Selection Sort : %.3f 초\n", (float)(end - start) / CLOCKS_PER_SEC);

    copy_array(original, test_array, N);
    start = clock();
    insertion_sort(test_array, N);
    end = clock();
    printf("Insertion Sort : %.3f 초\n", (float)(end - start) / CLOCKS_PER_SEC);

    copy_array(original, test_array, N);
    start = clock();
    merge_sort(test_array, 0, N - 1);
    end = clock();
    printf("Merge Sort     : %.3f 초 \n", (float)(end - start) / CLOCKS_PER_SEC);

    copy_array(original, test_array, N);
    start = clock();
    quick_sort(test_array, 0, N - 1);
    end = clock();
    printf("Quick Sort     : %.3f 초 \n", (float)(end - start) / CLOCKS_PER_SEC);

    free(original);
    free(test_array);
    free(sorted);
    return 0;
}
