#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "student.h"

Student* createStudent(
    int id,
    char* name,
    int kor,
    int eng,
    int math)
{
    Student* s =
        (Student*)malloc(sizeof(Student));

    s->id = id;

    strcpy(s->name, name);

    s->korean = kor;
    s->english = eng;
    s->math = math;

    s->average =
        (kor + eng + math) / 3.0;

    s->next = NULL;

    return s;
}
