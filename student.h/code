#ifndef STUDENT_H
#define STUDENT_H

#define NAME_LEN 50

typedef struct Student {
    int id;                     // 학번
    char name[NAME_LEN];        // 이름

    int korean;
    int english;
    int math;

    float average;

    struct Student* next;
} Student;

// 학생 생성
Student* createStudent(
    int id,
    char* name,
    int kor,
    int eng,
    int math);

// 평균 계산
float calculateAverage(
    int kor,
    int eng,
    int math);

// 학생 정보 출력
void printStudent(
    Student* student);

#endif
